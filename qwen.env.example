# Qwen 配置示例
# 复制此文件为 .env 并填入您的实际配置

# ============================================
# Qwen API 配置（只需配置这两项！）
# ============================================

# 必需：启用 Qwen 提供商
CLAUDE_CODE_USE_QWEN=true

# 必需：Qwen API 密钥
# 从阿里云 DashScope 控制台获取: https://dashscope.console.aliyun.com/
# 支持两种环境变量名称（任选其一）：
DASHSCOPE_API_KEY=sk-your-api-key-here
# 或
# QWEN_API_KEY=sk-your-api-key-here

# ============================================
# 以下配置已预设，通常无需修改
# ============================================

# 模型名称（已预配置）
# 默认: qwen-plus-latest
# ANTHROPIC_MODEL=qwen

# API 端点（已预配置）
# 默认: https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================
# 其他可选配置
# ============================================

# API 超时时间（毫秒）
# API_TIMEOUT_MS=600000

# 禁用提示缓存
# DISABLE_PROMPT_CACHING=false

# 代理配置（如果需要）
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080

# ============================================
# 使用说明
# ============================================
#
# 1. 将此文件复制为 .env:
#    cp qwen.env.example .env
#
# 2. 编辑 .env 文件，只需填入两项：
#    - CLAUDE_CODE_USE_QWEN=true
#    - DASHSCOPE_API_KEY=sk-your-key
#
# 3. 启动应用:
#    bun run dev --model qwen
#
# 或者直接在命令行设置环境变量:
#    export CLAUDE_CODE_USE_QWEN=true
#    export DASHSCOPE_API_KEY=sk-your-key
#    bun run dev --model qwen
